{
    "name": "kine-poli-app",
    "version": "1.0.0",
    "description": "App PWA para preguntas adaptativas en kinesiología",
    "private": true,
    "workspaces": [
        "apps/*",
        "tools/*"
    ],
    "scripts": {
        "dev": "npm --workspace=web run dev",
        "build": "npm --workspace=web run build",
        "test": "npm --workspace=web run test",
        "lint": "npm --workspace=web run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
    },
    "devDependencies": {
        "firebase-tools": "^15.10.1",
        "prettier": "^3.2.5"
    }
}
