rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones auxiliares
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        || request.auth.uid == 'OCxaQqfteHN2T4SVz2vsfDooEel2'
      );
    }
    
    // Colecciones de Administraci\u00f3n
    match /config/{document=**} {
      allow read, write: if isAdmin();
    }
    match /groups/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Colecciones de Contenido (Lectura P\u00daBLICA para usuarios autenticados)
    // Esto asegura que estudiantes y admins vean las preguntas SIEMPRE
    match /units/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /questions/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /cases/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Sesiones y Datos Privados
    match /sessions/{sessionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      match /attempts/{document=**} {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
      match /mastery/{document=**} {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
      match /tag_mastery/{document=**} {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
      match /family_mastery/{document=**} {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
